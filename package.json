{
  "name": "@cinatra-ai/list-curator-agent",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "description": "Orchestrator agent that curates a CRM list of accounts OR contacts from a natural-language intent. Invokes @cinatra-ai/web-scrape-agent → @cinatra-ai/company-discovery-agent → @cinatra-ai/contact-discovery-agent via agent_run, pauses at 2 HITL gates (scrape-schema-review + final-list-review), and materializes the resulting CRM list via crm_list_create + per-member crm_list_member_add after operator approval. The mixed member type is not supported — CRM lists are per-object-type.",
  "type": "module",
  "files": [
    "src",
    "!src/__tests__",
    "cinatra",
    "skills"
  ],
  "scripts": {
    "test": "vitest"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "radix-ui": "^1.6.0",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@cinatra-ai/sdk-ui": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-ui": {
      "optional": true
    }
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "displayName": "List Curator Agent",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/web-scrape-agent",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "semver-range",
          "range": "*"
        },
        "requirement": "required",
        "kind": "agent"
      },
      {
        "packageName": "@cinatra-ai/company-discovery-agent",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "semver-range",
          "range": "*"
        },
        "requirement": "optional",
        "kind": "agent"
      },
      {
        "packageName": "@cinatra-ai/contact-discovery-agent",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "semver-range",
          "range": "*"
        },
        "requirement": "optional",
        "kind": "agent"
      }
    ],
    "fieldRenderers": [
      {
        "id": "@cinatra-ai/list-curator-agent:scrape-schema-review",
        "kind": "scrape-schema-review",
        "priority": 90,
        "component": {
          "entry": "./src/list-curator-scrape-schema-renderer.tsx",
          "propsApiVersion": 1
        }
      },
      {
        "id": "@cinatra-ai/list-curator-agent:final-list-review",
        "kind": "final-list-review",
        "priority": 90,
        "component": {
          "entry": "./src/list-curator-final-list-renderer.tsx",
          "propsApiVersion": 1
        }
      }
    ],
    "consumes": [
      {
        "primitive": "crm_account_get",
        "requirement": "required"
      },
      {
        "primitive": "crm_list_create",
        "requirement": "required"
      },
      {
        "primitive": "crm_list_member_add",
        "requirement": "required"
      }
    ],
    "packageType": "agent",
    "manifestVersion": 1,
    "sourceTemplateId": "list-curator-agent-flow",
    "sourceVersionId": "5cd6c578-f94c-42e8-80d1-e6e87a6b1ae1",
    "sourceVersionNumber": 1,
    "riskLevel": "low",
    "hasApprovalGates": false,
    "toolAccess": [],
    "ownerOrgId": null
  }
}
